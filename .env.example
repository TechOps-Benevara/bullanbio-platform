# ════════════════════════════════════════════════════════════
#  BULLAN BIO DIGITAL PLATFORM — ENVIRONMENT VARIABLES
# ════════════════════════════════════════════════════════════
#  Copy this file to .env.local and fill in the real values.
#  NEVER commit .env.local — it is git-ignored.
#  Variable names below match exactly what the app reads (src/lib/env.ts).
#  In Vercel: set these per environment (Production / Preview / Development).
# ════════════════════════════════════════════════════════════

# ─── Required (Sprint 1 — app refuses to start without these) ───

# Supabase — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses RLS — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk → Webhooks → signing secret (for /api/webhooks/clerk)
CLERK_WEBHOOK_SECRET=

# App URL — http://localhost:3000 (dev) / https://bullanbio.com (prod)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Encryption key for NRIC / passport numbers (32 bytes, hex).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Back this up securely — if lost, encrypted data cannot be recovered.
ENCRYPTION_KEY=

# ─── Optional (post-MVP — leave blank until those features land) ───

# Xero (finance module) — Xero developer portal
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Airwallex (payments) — Airwallex dashboard → API Keys
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=

# ipinfo.io token — production geolocation (replaces ip-api.com)
IPINFO_TOKEN=
